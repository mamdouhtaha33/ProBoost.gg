generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  PRO
  ADMIN
}

enum OrderStatus {
  OPEN
  ASSIGNED
  IN_PROGRESS
  DELIVERED
  COMPLETED
  CANCELLED
  REFUND_REVIEW
  REFUNDED
}

enum BidStatus {
  PENDING
  ACCEPTED
  REJECTED
  WITHDRAWN
}

enum ProApplicationStatus {
  NOT_APPLIED
  PENDING
  APPROVED
  REJECTED
}

enum PaymentProvider {
  MANUAL
  STRIPE
  PAYMOB
}

enum Locale {
  EN
  AR
  ES
}

enum Currency {
  USD
  EUR
  EGP
  SAR
}

enum ProRank {
  UNRANKED
  BRONZE
  SILVER
  GOLD
  PLATINUM
  DIAMOND
}

enum DisputeStatus {
  OPEN
  UNDER_REVIEW
  AWAITING_USER
  AWAITING_PRO
  RESOLVED_FOR_USER
  RESOLVED_FOR_PRO
  CLOSED
}

enum DisputeReason {
  NOT_DELIVERED
  PARTIAL_DELIVERY
  QUALITY_ISSUE
  COMMUNICATION
  PAYMENT_ISSUE
  OTHER
}

enum NotificationType {
  ORDER_CREATED
  ORDER_PAID
  BID_PLACED
  BID_ACCEPTED
  BID_REJECTED
  STATUS_CHANGED
  MESSAGE_RECEIVED
  REVIEW_RECEIVED
  REFUND_REQUESTED
  DISPUTE_OPENED
  DISPUTE_UPDATED
  REFERRAL_REWARD
  PRO_APPLICATION_UPDATE
}

enum EmailStatus {
  QUEUED
  SENT
  FAILED
  SKIPPED
}

enum BlogPostStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum ReferralStatus {
  PENDING
  SIGNED_UP
  ORDER_PLACED
  REWARD_GRANTED
  EXPIRED
}

enum AuditTargetType {
  ORDER
  USER
  PAYMENT
  BID
  REVIEW
  PRO_APPLICATION
  DISPUTE
  AUTO_ASSIGNMENT_RULE
  BLOG_POST
  REFERRAL
  CONFIG
}

enum PaymentStatus {
  PENDING
  REQUIRES_ACTION
  PROCESSING
  PAID
  FAILED
  REFUND_REQUESTED
  REFUNDED
  CANCELLED
}

enum TransactionKind {
  CHARGE
  REFUND
  PAYOUT
  ADJUSTMENT
}

enum TransactionStatus {
  PENDING
  SUCCEEDED
  FAILED
  CANCELLED
}

enum OrderActivityType {
  CREATED
  PAYMENT_PENDING
  PAYMENT_LINK_CREATED
  PAYMENT_CONFIRMED
  BID_PLACED
  BID_WITHDRAWN
  BID_ACCEPTED
  STATUS_CHANGED
  ASSIGNED
  MESSAGE_SENT
  INTERNAL_NOTE_ADDED
  CANCELLATION_REQUESTED
  REFUND_REQUESTED
  REFUND_APPROVED
  REFUND_REJECTED
  REVIEW_LEFT
  PRO_APPLICATION_SUBMITTED
  PRO_APPLICATION_APPROVED
  PRO_APPLICATION_REJECTED
}

enum RefundRequestStatus {
  NONE
  REQUESTED
  APPROVED
  REJECTED
  COMPLETED
}

enum ConversationParticipantRole {
  USER
  PRO
  ADMIN
  SYSTEM
}

model User {
  id                   String               @id @default(cuid())
  name                 String?
  email                String               @unique
  emailVerified        DateTime?
  image                String?
  role                 Role                 @default(USER)
  proApplicationStatus ProApplicationStatus @default(NOT_APPLIED)
  proHeadline          String?
  proBio               String?              @db.Text
  payoutEmail          String?
  handle               String?              @unique
  locale               Locale               @default(EN)
  currency             Currency             @default(USD)
  twoFactorEnabled     Boolean              @default(false)
  referralCode         String?              @unique
  referredById         String?
  proRank              ProRank              @default(UNRANKED)
  proCompletedJobs     Int                  @default(0)
  proAverageRating     Float?
  proLanguages         String[]             @default([])
  proCountry           String?
  proVerified          Boolean              @default(false)
  walletCreditCents    Int                  @default(0)
  marketingConsent     Boolean              @default(false)
  cookieConsent        Boolean?
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt

  accounts          Account[]
  sessions          Session[]
  ordersPlaced      Order[]          @relation("OrdersPlaced")
  ordersClaimed     Order[]          @relation("OrdersClaimed")
  bids              Bid[]
  activities        OrderActivity[]  @relation("ActivityActor")
  messagesSent      Message[]        @relation("MessageSender")
  reviewsWritten    Review[]         @relation("ReviewAuthor")
  reviewsReceived   Review[]         @relation("ReviewRecipient")
  proApplication    ProApplication?
  twoFactor         TwoFactorSecret?
  notifications     Notification[]
  disputesOpened    Dispute[]        @relation("DisputeOpener")
  disputesAssigned  Dispute[]        @relation("DisputeAssignee")
  disputeMessages   DisputeMessage[]
  auditEvents       AuditLog[]       @relation("AuditActor")
  referredBy        User?            @relation("UserReferrals", fields: [referredById], references: [id], onDelete: SetNull)
  referralsMade     User[]           @relation("UserReferrals")
  referralsCreated  Referral[]       @relation("ReferralReferrer")
  referralsReceived Referral[]       @relation("ReferralReferred")
  blogPosts         BlogPost[]       @relation("BlogAuthor")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Order {
  id                    String              @id @default(cuid())
  customerId            String
  proId                 String?
  acceptedBidId         String?             @unique
  service               String
  game                  String              @default("ARC Raiders")
  gameSlug              String              @default("arc-raiders")
  title                 String
  description           String              @db.Text
  options               Json
  basePrice             Int
  finalPrice            Int?
  currency              String              @default("USD")
  displayCurrency       Currency            @default(USD)
  displayAmountCents    Int?
  exchangeRate          Float?
  paymentProvider       PaymentProvider     @default(MANUAL)
  paymentStatus         PaymentStatus       @default(PENDING)
  refundRequestStatus   RefundRequestStatus @default(NONE)
  internalNotes         String?             @db.Text
  cancellationReason    String?             @db.Text
  customerRequestedAt   DateTime?
  refundedAt            DateTime?
  autoAssignedFromBidId String?
  status                OrderStatus         @default(OPEN)
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt

  customer            User            @relation("OrdersPlaced", fields: [customerId], references: [id])
  pro                 User?           @relation("OrdersClaimed", fields: [proId], references: [id])
  bids                Bid[]
  payment             Payment?
  transactions        Transaction[]
  activities          OrderActivity[]
  conversation        Conversation?
  review              Review?
  disputes            Dispute[]
  referralsAttributed Referral[]      @relation("ReferralAttributedOrder")

  @@index([status])
  @@index([customerId])
  @@index([proId])
  @@index([paymentStatus])
  @@index([refundRequestStatus])
  @@index([gameSlug])
}

model Bid {
  id        String    @id @default(cuid())
  orderId   String
  proId     String
  amount    Int
  message   String?   @db.Text
  status    BidStatus @default(PENDING)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
  pro   User  @relation(fields: [proId], references: [id], onDelete: Cascade)

  @@unique([orderId, proId])
  @@index([orderId])
  @@index([proId])
  @@index([status])
}

model Payment {
  id          String          @id @default(cuid())
  orderId     String          @unique
  provider    PaymentProvider @default(MANUAL)
  status      PaymentStatus   @default(PENDING)
  amount      Int
  currency    String          @default("USD")
  providerRef String?
  checkoutUrl String?
  lastError   String?         @db.Text
  metadata    Json?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  paidAt      DateTime?

  order        Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)
  transactions Transaction[]

  @@index([status])
  @@index([provider])
}

model Transaction {
  id          String            @id @default(cuid())
  orderId     String
  paymentId   String?
  kind        TransactionKind
  status      TransactionStatus @default(PENDING)
  amount      Int
  currency    String            @default("USD")
  providerRef String?
  description String?
  metadata    Json?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  order   Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  payment Payment? @relation(fields: [paymentId], references: [id], onDelete: SetNull)

  @@index([orderId])
  @@index([paymentId])
  @@index([status])
  @@index([kind])
}

model OrderActivity {
  id            String            @id @default(cuid())
  orderId       String
  actorUserId   String?
  type          OrderActivityType
  message       String            @db.Text
  metadata      Json?
  visibleToPro  Boolean           @default(true)
  visibleToUser Boolean           @default(true)
  createdAt     DateTime          @default(now())

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
  actor User? @relation("ActivityActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([orderId, createdAt])
  @@index([actorUserId])
  @@index([type])
}

model Conversation {
  id        String   @id @default(cuid())
  orderId   String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  order    Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  messages Message[]
}

model Message {
  id             String                      @id @default(cuid())
  conversationId String
  senderId       String?
  senderRole     ConversationParticipantRole
  body           String                      @db.Text
  isInternal     Boolean                     @default(false)
  createdAt      DateTime                    @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User?        @relation("MessageSender", fields: [senderId], references: [id], onDelete: SetNull)

  @@index([conversationId, createdAt])
  @@index([senderId])
}

model Review {
  id          String   @id @default(cuid())
  orderId     String   @unique
  authorId    String
  recipientId String
  rating      Int
  title       String?
  body        String?  @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  order     Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
  author    User  @relation("ReviewAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  recipient User  @relation("ReviewRecipient", fields: [recipientId], references: [id], onDelete: Cascade)

  @@index([authorId])
  @@index([recipientId])
}

model ProApplication {
  id           String               @id @default(cuid())
  userId       String               @unique
  status       ProApplicationStatus @default(PENDING)
  headline     String
  bio          String               @db.Text
  experience   String?              @db.Text
  availability String?
  adminNotes   String?              @db.Text
  reviewedById String?
  reviewedAt   DateTime?
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([status])
}

model TwoFactorSecret {
  id            String   @id @default(cuid())
  userId        String   @unique
  secret        String
  enabled       Boolean  @default(false)
  recoveryCodes String[]
  enrolledAt    DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType
  title     String
  body      String           @db.Text
  link      String?
  read      Boolean          @default(false)
  metadata  Json?
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read, createdAt])
  @@index([type])
}

model Dispute {
  id          String        @id @default(cuid())
  orderId     String
  openerId    String
  assigneeId  String?
  status      DisputeStatus @default(OPEN)
  reason      DisputeReason
  summary     String        @db.Text
  resolution  String?       @db.Text
  amountClaim Int?
  closedAt    DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  order    Order            @relation(fields: [orderId], references: [id], onDelete: Cascade)
  opener   User             @relation("DisputeOpener", fields: [openerId], references: [id], onDelete: Cascade)
  assignee User?            @relation("DisputeAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  messages DisputeMessage[]

  @@index([orderId])
  @@index([status])
  @@index([openerId])
}

model DisputeMessage {
  id         String   @id @default(cuid())
  disputeId  String
  authorId   String
  body       String   @db.Text
  isInternal Boolean  @default(false)
  createdAt  DateTime @default(now())

  dispute Dispute @relation(fields: [disputeId], references: [id], onDelete: Cascade)
  author  User    @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([disputeId, createdAt])
}

model AuditLog {
  id          String          @id @default(cuid())
  actorUserId String?
  action      String
  targetType  AuditTargetType
  targetId    String
  before      Json?
  after       Json?
  ip          String?
  userAgent   String?
  createdAt   DateTime        @default(now())

  actor User? @relation("AuditActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([targetType, targetId])
  @@index([actorUserId])
  @@index([createdAt])
}

model AutoAssignmentRule {
  id                 String   @id @default(cuid())
  name               String
  gameSlug           String?
  service            String?
  minProRank         ProRank  @default(GOLD)
  maxBidPercent      Int      @default(110)
  minBidPercent      Int      @default(60)
  requireProVerified Boolean  @default(true)
  enabled            Boolean  @default(true)
  priority           Int      @default(100)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([enabled, priority])
}

model EmailLog {
  id           String      @id @default(cuid())
  toEmail      String
  templateName String
  subject      String
  status       EmailStatus @default(QUEUED)
  providerRef  String?
  error        String?     @db.Text
  metadata     Json?
  sentAt       DateTime?
  createdAt    DateTime    @default(now())

  @@index([toEmail])
  @@index([templateName])
  @@index([status])
}

model BlogPost {
  id          String         @id @default(cuid())
  slug        String         @unique
  authorId    String
  title       String
  excerpt     String?        @db.Text
  body        String         @db.Text
  coverImage  String?
  status      BlogPostStatus @default(DRAFT)
  tags        String[]       @default([])
  locale      Locale         @default(EN)
  publishedAt DateTime?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  author User @relation("BlogAuthor", fields: [authorId], references: [id], onDelete: Cascade)

  @@index([status, publishedAt])
  @@index([locale])
}

model Referral {
  id                String         @id @default(cuid())
  referrerId        String
  referredEmail     String
  referredUserId    String?
  attributedOrderId String?
  rewardCents       Int            @default(0)
  status            ReferralStatus @default(PENDING)
  expiresAt         DateTime?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  referrer        User   @relation("ReferralReferrer", fields: [referrerId], references: [id], onDelete: Cascade)
  referred        User?  @relation("ReferralReferred", fields: [referredUserId], references: [id], onDelete: SetNull)
  attributedOrder Order? @relation("ReferralAttributedOrder", fields: [attributedOrderId], references: [id], onDelete: SetNull)

  @@index([referrerId])
  @@index([referredUserId])
  @@index([status])
}

model RateLimitBucket {
  key       String   @id
  count     Int      @default(0)
  resetAt   DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([resetAt])
}
