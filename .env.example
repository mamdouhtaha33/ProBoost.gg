# PostgreSQL connection string
# Local docker-compose: postgresql://postgres:postgres@localhost:5432/arc_marketplace?schema=public
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/arc_marketplace?schema=public"

# NextAuth / Auth.js
# Generate with: openssl rand -base64 32
AUTH_SECRET="replace-me-with-a-strong-secret"
# Optional in dev; required in production
NEXTAUTH_URL="http://localhost:3000"

# Google OAuth (https://console.cloud.google.com/apis/credentials)
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# Bootstrap: comma-separated emails that will be auto-promoted to ADMIN on first login
ADMIN_EMAILS=""
