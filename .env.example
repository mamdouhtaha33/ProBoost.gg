# =============================================================================
# Database
# =============================================================================
# Local docker-compose: postgresql://postgres:postgres@localhost:5432/arc_marketplace?schema=public
# Production: Neon, Supabase, Railway, or Vercel Postgres connection string.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/arc_marketplace?schema=public"

# =============================================================================
# NextAuth / Auth.js (https://authjs.dev/)
# =============================================================================
# Generate with: openssl rand -base64 32
AUTH_SECRET="replace-me-with-a-strong-secret"
# Required in production; the canonical site URL.
NEXTAUTH_URL="http://localhost:3000"
# Used for absolute URLs (canonical, OG, sitemap). Falls back to NEXTAUTH_URL.
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# Google OAuth (https://console.cloud.google.com/apis/credentials)
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# Comma-separated emails auto-promoted to ADMIN on first sign-in.
ADMIN_EMAILS=""

# =============================================================================
# Payments
# =============================================================================
# When both keys are set, ProBoost.gg switches to the Stripe provider.
# Without them, the app uses a MANUAL provider that simulates checkout in dev.
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""

# =============================================================================
# Observability (optional)
# =============================================================================
# SENTRY_DSN=""
# AXIOM_TOKEN=""
